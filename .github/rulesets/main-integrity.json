            "integration_id": 15368
          },
          {
            "context": "chezmoi-parity-macos",
            "integration_id": 15368
          },
          {
            "context": "chezmoi-parity-windows",
            "integration_id": 15368
          },
          {
            "context": "nix flake check / linux",
            "integration_id": 15368
          },
          {
            "context": "nix flake check / macos",
            "integration_id": 15368
          },
          {
            "context": "e2e containers / linux",
            "integration_id": 15368
          },
          {
            "context": "setup.sh / linux",
            "integration_id": 15368
          },
          {
            "context": "setup.sh / macos",
            "integration_id": 15368
          },
          {
            "context": "setup.ps1 / windows",
            "integration_id": 15368
          }
