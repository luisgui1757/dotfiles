{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate owns GitHub Actions and repo-pinned version/ref constants only. Direct-download SHA-256 values must still be recomputed and reviewed by a human after version/ref bumps.",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":dependencyDashboard",
    ":semanticCommits",
    ":timezone(Etc/UTC)"
  ],
  "enabledManagers": ["github-actions", "custom.regex"],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate dashboard",
  "schedule": ["before 06:00 on monday"],
  "prConcurrentLimit": 4,
  "prHourlyLimit": 2,
  "labels": ["dependencies"],
  "automerge": false,
  "rebaseWhen": "conflicted",
  "vulnerabilityAlerts": {
    "enabled": false
  },
  "lockFileMaintenance": {
    "enabled": false
  },
  "ignorePaths": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.venv/**",
    "tests/.cache/**",
    "vendor/**"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Neovim Linux x86_64 tarball version. The adjacent SHA-256 must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^install-deps\\.sh$/"],
      "matchStrings": [
        "NVIM_LINUX_VERSION=\"(?<currentValue>v[^\"]+)\"\\s+NVIM_LINUX_X86_64_SHA256=\"[a-f0-9]{64}\""
      ],
      "depNameTemplate": "neovim/neovim",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Neovim Linux arm64 tarball version. The adjacent SHA-256 must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^install-deps\\.sh$/"],
      "matchStrings": [
        "NVIM_LINUX_VERSION=\"(?<currentValue>v[^\"]+)\"(?:.|\\n)*?NVIM_LINUX_ARM64_SHA256=\"[a-f0-9]{64}\""
      ],
      "depNameTemplate": "neovim/neovim",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Neovim Linux x86_64 tarball version in CI. The adjacent SHA-256 must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^\\.github/workflows/test\\.yml$/"],
      "matchStrings": [
        "NVIM_LINUX_VERSION:\\s*(?<currentValue>v[^\\s]+)\\s+NVIM_LINUX_X86_64_SHA256:\\s*[a-f0-9]{64}"
      ],
      "depNameTemplate": "neovim/neovim",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Hack Nerd Font archive version for Unix. The SHA-256 must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^install-deps\\.sh$/"],
      "matchStrings": [
        "HACK_NERD_FONT_VERSION=\"(?<currentValue>v[^\"]+)\"\\s+HACK_NERD_FONT_SHA256=\"[a-f0-9]{64}\""
      ],
      "depNameTemplate": "ryanoasis/nerd-fonts",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Hack Nerd Font archive version for Windows. The SHA-256 must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^install-deps\\.ps1$/"],
      "matchStrings": [
        "\\$HackNerdFontVersion\\s*=\\s*'(?<currentValue>v[^']+)'\\s+\\$HackNerdFontSha256\\s*=\\s*'[a-f0-9]{64}'"
      ],
      "depNameTemplate": "ryanoasis/nerd-fonts",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Windows Terminal portable archive version for Windows. The SHA-256 must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^install-deps\\.ps1$/"],
      "matchStrings": [
        "\\$WindowsTerminalVersion\\s*=\\s*'(?<currentValue>v[^']+)'\\s+\\$WindowsTerminalX64Sha256\\s*=\\s*'[a-f0-9]{64}'"
      ],
      "depNameTemplate": "microsoft/terminal",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "description": "Ubuntu Ghostty installer version. The installer SHA-256 must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^install-deps\\.sh$/"],
      "matchStrings": [
        "GHOSTTY_UBUNTU_VERSION=\"(?<currentValue>[^\"]+)\"\\s+GHOSTTY_UBUNTU_INSTALL_SHA256=\"[a-f0-9]{64}\""
      ],
      "depNameTemplate": "mkasberg/ghostty-ubuntu",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "description": "Homebrew installer script commit pinned to the current main branch digest. The adjacent installer script SHA-256 must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^install-deps\\.sh$/"],
      "matchStrings": [
        "HOMEBREW_INSTALL_COMMIT=\"(?<currentDigest>[a-f0-9]{40})\"\\s+HOMEBREW_INSTALL_SHA256=\"[a-f0-9]{64}\""
      ],
      "currentValueTemplate": "main",
      "depNameTemplate": "Homebrew/install",
      "packageNameTemplate": "https://github.com/Homebrew/install",
      "datasourceTemplate": "git-refs"
    },
    {
      "customType": "regex",
      "description": "chezmoi Linux x86_64 release version. Adjacent Linux asset SHA-256 values must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^install-deps\\.sh$/"],
      "matchStrings": [
        "CHEZMOI_VERSION=\"(?<currentValue>v[^\"]+)\"\\s+CHEZMOI_LINUX_X86_64_SHA256=\"[a-f0-9]{64}\""
      ],
      "depNameTemplate": "twpayne/chezmoi",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "chezmoi Linux arm64 release version. Adjacent Linux asset SHA-256 values must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^install-deps\\.sh$/"],
      "matchStrings": [
        "CHEZMOI_VERSION=\"(?<currentValue>v[^\"]+)\"(?:.|\\n)*?CHEZMOI_LINUX_ARM64_SHA256=\"[a-f0-9]{64}\""
      ],
      "depNameTemplate": "twpayne/chezmoi",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "chezmoi release version in CI. Adjacent Linux/macOS/Windows asset SHA-256 values must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^\\.github/workflows/test\\.yml$/"],
      "matchStrings": [
        "CHEZMOI_VERSION:\\s*(?<currentValue>v[^\\s]+)\\s+CHEZMOI_LINUX_X86_64_SHA256:\\s*[a-f0-9]{64}"
      ],
      "depNameTemplate": "twpayne/chezmoi",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "lazygit Linux release version. Adjacent Linux asset SHA-256 values must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^install-deps\\.sh$/"],
      "matchStrings": [
        "LAZYGIT_LINUX_VERSION=\"(?<currentValue>v[^\"]+)\"\\s+LAZYGIT_LINUX_X86_64_SHA256=\"[a-f0-9]{64}\""
      ],
      "depNameTemplate": "jesseduffield/lazygit",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "lazygit Linux arm64 release version. Adjacent Linux asset SHA-256 values must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^install-deps\\.sh$/"],
      "matchStrings": [
        "LAZYGIT_LINUX_VERSION=\"(?<currentValue>v[^\"]+)\"(?:.|\\n)*?LAZYGIT_LINUX_ARM64_SHA256=\"[a-f0-9]{64}\""
      ],
      "depNameTemplate": "jesseduffield/lazygit",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Starship Linux x86_64 release version. Adjacent Linux asset SHA-256 values must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^install-deps\\.sh$/"],
      "matchStrings": [
        "STARSHIP_VERSION=\"(?<currentValue>v[^\"]+)\"\\s+STARSHIP_LINUX_X86_64_SHA256=\"[a-f0-9]{64}\""
      ],
      "depNameTemplate": "starship/starship",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Starship Linux arm64 release version. Adjacent Linux asset SHA-256 values must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^install-deps\\.sh$/"],
      "matchStrings": [
        "STARSHIP_VERSION=\"(?<currentValue>v[^\"]+)\"(?:.|\\n)*?STARSHIP_LINUX_ARM64_SHA256=\"[a-f0-9]{64}\""
      ],
      "depNameTemplate": "starship/starship",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Starship Linux x86_64 release version in CI. The adjacent SHA-256 must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^\\.github/workflows/test\\.yml$/"],
      "matchStrings": [
        "STARSHIP_VERSION:\\s*(?<currentValue>v[^\\s]+)\\s+STARSHIP_LINUX_X86_64_SHA256:\\s*[a-f0-9]{64}"
      ],
      "depNameTemplate": "starship/starship",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "tree-sitter CLI Linux x86_64 release version. Adjacent Linux asset SHA-256 values must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^install-deps\\.sh$/"],
      "matchStrings": [
        "TREE_SITTER_CLI_LINUX_VERSION=\"(?<currentValue>v[^\"]+)\"\\s+TREE_SITTER_CLI_LINUX_X86_64_SHA256=\"[a-f0-9]{64}\""
      ],
      "depNameTemplate": "tree-sitter/tree-sitter",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "tree-sitter CLI Linux x86_64 release version in CI. The adjacent SHA-256 must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^\\.github/workflows/test\\.yml$/"],
      "matchStrings": [
        "TREE_SITTER_CLI_LINUX_VERSION:\\s*(?<currentValue>v[^\\s]+)\\s+TREE_SITTER_CLI_LINUX_X86_64_SHA256:\\s*[a-f0-9]{64}"
      ],
      "depNameTemplate": "tree-sitter/tree-sitter",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "tree-sitter CLI Linux arm64 release version. Adjacent Linux asset SHA-256 values must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^install-deps\\.sh$/"],
      "matchStrings": [
        "TREE_SITTER_CLI_LINUX_VERSION=\"(?<currentValue>v[^\"]+)\"(?:.|\\n)*?TREE_SITTER_CLI_LINUX_ARM64_SHA256=\"[a-f0-9]{64}\""
      ],
      "depNameTemplate": "tree-sitter/tree-sitter",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "fzf-tab pinned tag. The adjacent commit SHA must be reviewed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^install-deps\\.sh$/"],
      "matchStrings": [
        "FZF_TAB_VERSION=\"(?<currentValue>v[^\"]+)\"\\s+FZF_TAB_COMMIT=\"[a-f0-9]{40}\""
      ],
      "depNameTemplate": "Aloxaf/fzf-tab",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "zsh-autosuggestions pinned tag. The adjacent commit SHA must be reviewed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^install-deps\\.sh$/"],
      "matchStrings": [
        "ZSH_AUTOSUGGESTIONS_VERSION=\"(?<currentValue>v[^\"]+)\"\\s+ZSH_AUTOSUGGESTIONS_COMMIT=\"[a-f0-9]{40}\""
      ],
      "depNameTemplate": "zsh-users/zsh-autosuggestions",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "gh-dash pinned gh-extension tag (install-deps.sh). Mirrored in install-deps.ps1; no adjacent SHA to recompute.",
      "managerFilePatterns": ["/^install-deps\\.sh$/"],
      "matchStrings": [
        "GH_DASH_VERSION=\"(?<currentValue>v[^\"]+)\""
      ],
      "depNameTemplate": "dlvhdr/gh-dash",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "gh-dash pinned gh-extension tag (install-deps.ps1). Mirrored in install-deps.sh; no adjacent SHA to recompute.",
      "managerFilePatterns": ["/^install-deps\\.ps1$/"],
      "matchStrings": [
        "\\$GhDashVersion\\s*=\\s*'(?<currentValue>v[^']+)'"
      ],
      "depNameTemplate": "dlvhdr/gh-dash",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "cargo-binstall installer script commit pinned to the current main branch digest. The adjacent installer script SHA-256 must be recomputed manually after Renovate bumps this.",
      "managerFilePatterns": ["/^\\.github/workflows/test\\.yml$/"],
      "matchStrings": [
        "CARGO_BINSTALL_COMMIT:\\s*(?<currentDigest>[a-f0-9]{40})\\s+CARGO_BINSTALL_INSTALLER_SHA256:\\s*[a-f0-9]{64}"
      ],
      "currentValueTemplate": "main",
      "depNameTemplate": "cargo-bins/cargo-binstall",
      "packageNameTemplate": "https://github.com/cargo-bins/cargo-binstall",
      "datasourceTemplate": "git-refs"
    },
    {
      "customType": "regex",
      "description": "Node runtime version used to run Renovate's schema validator.",
      "managerFilePatterns": ["/^scripts/validate-renovate\\.sh$/"],
      "matchStrings": [
        "RENOVATE_NODE_VERSION=\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "node",
      "datasourceTemplate": "npm",
      "versioningTemplate": "node"
    },
    {
      "customType": "regex",
      "description": "Renovate package version used by the required schema validator.",
      "managerFilePatterns": ["/^scripts/validate-renovate\\.sh$/"],
      "matchStrings": [
        "RENOVATE_VERSION=\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "renovate",
      "datasourceTemplate": "npm",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "groupName": "pinned installer constants",
      "addLabels": ["pinned-downloads"],
      "automerge": false
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "addLabels": ["github-actions"],
      "pinDigests": true,
      "automerge": false
    },
    {
      "matchManagers": ["github-actions"],
      "matchDatasources": ["github-runners"],
      "groupName": "github runner images",
      "addLabels": ["github-runners"],
      "automerge": false
    }
  ]
}
