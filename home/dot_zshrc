#!/usr/bin/env zsh
# shellcheck shell=bash  # closest available to zsh; expect false positives
# shellcheck disable=SC1009,SC1036,SC1072,SC1073  # zsh-only glob qualifiers
# Cross-platform zsh init. Safe on macOS (Homebrew), WSL Ubuntu, plain Linux.

# ---- Locale (set early so anything that reads LANG gets it) ------------------
_dotfiles_locale=""
if command -v locale >/dev/null 2>&1; then
  if locale -a 2>/dev/null | grep -qxE 'en_US\.(UTF-8|utf8)'; then
    _dotfiles_locale="en_US.UTF-8"
  elif locale -a 2>/dev/null | grep -qxE 'C\.(UTF-8|utf8)'; then
    _dotfiles_locale="C.UTF-8"
  fi
fi
if [[ -n "$_dotfiles_locale" ]]; then
  export LANG="$_dotfiles_locale"
  export LC_ALL="$_dotfiles_locale"
  export LANGUAGE="$_dotfiles_locale"
  export LC_MESSAGES="$_dotfiles_locale"
fi
unset _dotfiles_locale

# ---- Homebrew detection (mac + linuxbrew) ------------------------------------
# $HOMEBREW_PREFIX is set by `brew shellenv`; if not in the environment yet,
# probe common locations rather than failing.
if [[ -z "${HOMEBREW_PREFIX:-}" ]]; then
  for candidate in /opt/homebrew /usr/local /home/linuxbrew/.linuxbrew "$HOME/.linuxbrew"; do
    if [[ -x "$candidate/bin/brew" ]]; then
      eval "$($candidate/bin/brew shellenv)"
      break
    fi
  done
fi

# ---- PATH (de-duplicating helper, order: user-local → brew → python → system)
# zsh's `typeset -U path` keeps the array unique automatically.
typeset -U path PATH
[[ -d "$HOME/.local/bin" ]] && path=("$HOME/.local/bin" $path)
[[ -d "$HOME/.cargo/bin" ]] && path=("$HOME/.cargo/bin" $path)
if [[ -n "${HOMEBREW_PREFIX:-}" ]]; then
  [[ -d "$HOMEBREW_PREFIX/opt/python@3.12/bin" ]] && path=("$HOMEBREW_PREFIX/opt/python@3.12/bin" $path)
  [[ -d "$HOMEBREW_PREFIX/bin" ]] && path=("$HOMEBREW_PREFIX/bin" $path)
fi
export PATH

# ---- Rose Pine file listing colors ------------------------------------------
# lsd reads LS_COLORS for file/directory names; zsh completion reuses the same
# palette through the list-colors zstyle below. Dotfiles owns this palette by
# default; set DOTFILES_LS_COLORS before shell startup for an explicit override.
_dotfiles_ls_colors=(
  'no=38;2;224;222;244'
  'fi=38;2;224;222;244'
  'di=38;2;246;193;119'
  'ln=38;2;196;167;231'
  'pi=38;2;156;207;216'
  'so=38;2;156;207;216'
  'do=38;2;156;207;216'
  'bd=38;2;235;188;186'
  'cd=38;2;235;188;186'
  'or=38;2;235;111;146'
  'mi=38;2;235;111;146'
  'su=38;2;235;111;146'
  'sg=38;2;246;193;119'
  'ca=38;2;235;188;186'
  'tw=38;2;246;193;119'
  'ow=38;2;246;193;119'
  'st=38;2;246;193;119'
  'ex=38;2;235;111;146'
  '*.md=38;2;156;207;216'
  '*.markdown=38;2;156;207;216'
  '*.txt=38;2;224;222;244'
  '*.toml=38;2;156;207;216'
  '*.yaml=38;2;156;207;216'
  '*.yml=38;2;156;207;216'
  '*.json=38;2;156;207;216'
  '*.jsonc=38;2;156;207;216'
  '*.lua=38;2;196;167;231'
  '*.vim=38;2;196;167;231'
  '*.sh=38;2;246;193;119'
  '*.bash=38;2;246;193;119'
  '*.zsh=38;2;246;193;119'
  '*.ps1=38;2;196;167;231'
  '*.zip=38;2;235;188;186'
  '*.tar=38;2;235;188;186'
  '*.gz=38;2;235;188;186'
  '*.tgz=38;2;235;188;186'
  '*.xz=38;2;235;188;186'
  '*.7z=38;2;235;188;186'
  '*.png=38;2;235;188;186'
  '*.jpg=38;2;235;188;186'
  '*.jpeg=38;2;235;188;186'
  '*.webp=38;2;235;188;186'
  '*.svg=38;2;156;207;216'
)
export LS_COLORS="${DOTFILES_LS_COLORS:-${(j.:.)_dotfiles_ls_colors}}"
unset _dotfiles_ls_colors

# ---- History -----------------------------------------------------------------
HISTFILE="${HOME}/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt SHARE_HISTORY HIST_IGNORE_DUPS HIST_IGNORE_ALL_DUPS HIST_REDUCE_BLANKS \
       HIST_IGNORE_SPACE HIST_VERIFY EXTENDED_HISTORY

# ---- zsh plugins -------------------------------------------------------------
# setup.sh/chezmoi install repo-managed pinned plugins under this fixed root.
# Runtime uses those first, then falls back to package-manager paths if a
# machine has not run the installer yet. Source exactly one readable path per
# plugin.
_dotfiles_source_first_readable() {
  local plugin
  for plugin in "$@"; do
    if [[ -r "$plugin" ]]; then
      source "$plugin"
      return 0
    fi
  done
  return 1
}

_dotfiles_zsh_plugin_root="$HOME/.local/share/dotfiles/zsh-plugins"

# ---- Completion: native compinit + fzf-tab fuzzy Tab menu (PowerShell-like) --
# Tab opens an fzf-driven, fuzzy-filterable, navigable, colored picker over zsh's
# REAL context-aware completions (git subcommands, ssh hosts, kill PIDs, env
# vars -- not just files): the analog of PowerShell's MenuComplete, with fuzzy
# narrowing on top. fzf-tab WRAPS the Tab widget, so it must load AFTER compinit
# + the completion zstyles and BEFORE zsh-autosuggestions, and it must be the
# LAST thing to own Tab (the fzf key-binding block below reclaims it). When fzf
# is absent it falls back to the native `menu-select` widget so a no-fzf machine
# still gets a usable menu (and zsh_startup_test stays green).
autoload -Uz compinit
mkdir -p "${HOME}/.cache"
_zcompdump="${HOME}/.cache/zcompdump-${ZSH_VERSION}"
if [[ -n "$_zcompdump"(#qN.mh+24) ]]; then
  compinit -d "$_zcompdump"
else
  compinit -C -d "$_zcompdump"
fi
unset _zcompdump
zmodload -i zsh/complist
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'   # case-insensitive matching
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"     # colorize entries
zstyle ':completion:*:descriptions' format '[%d]'           # fzf-tab group headers

if command -v fzf >/dev/null 2>&1; then
  # fzf-tab renders the menu via fzf, so zsh's own menu must be OFF.
  zstyle ':completion:*' menu no
  zstyle ':fzf-tab:*' switch-group '<' '>'
  zstyle ':fzf-tab:*' fzf-min-height 15
  zstyle ':fzf-tab:*' fzf-flags --color=hl:#f6c177,hl+:#f6c177   # gold = selected (Rose Pine)
  zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls -1p -- "$realpath" 2>/dev/null'
  if ! _dotfiles_source_first_readable \
      "$_dotfiles_zsh_plugin_root/fzf-tab/fzf-tab.plugin.zsh"; then
    # fzf present but fzf-tab not installed yet -> native menu fallback.
    zstyle ':completion:*' menu select
    bindkey '^I' menu-select
  fi
else
  zstyle ':completion:*' menu select                        # no fzf -> native menu
  bindkey '^I' menu-select
fi

# Inline gray history suggestion (the PowerShell InlinePrediction analog; accept
# the whole suggestion with Right-arrow / End). Loads AFTER fzf-tab so widget
# wrapping order is correct. The one zsh plugin sourced for prediction.
ZSH_AUTOSUGGEST_STRATEGY=(history completion)               # ~ HistoryAndPlugin
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=#908caa'                # match PS InlinePrediction
ZSH_AUTOSUGGEST_MANUAL_REBIND=1                             # perf: no per-prompt rebinds
_dotfiles_source_first_readable \
  "$_dotfiles_zsh_plugin_root/zsh-autosuggestions/zsh-autosuggestions.zsh" \
  "${HOMEBREW_PREFIX:-}/share/zsh-autosuggestions/zsh-autosuggestions.zsh" \
  "/usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh"

# Up / Down = prefix history search (PowerShell HistorySearchBackward/Forward).
autoload -Uz up-line-or-beginning-search down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search
bindkey '^[[A' up-line-or-beginning-search
bindkey '^[[B' down-line-or-beginning-search

unset _dotfiles_zsh_plugin_root
unfunction _dotfiles_source_first_readable 2>/dev/null || true

# ---- Starship init (precompiled, like the PowerShell profile) ---------------
# Re-generate when the toml is newer than the cached init script, so config
# tweaks always take effect. Falls back to live init if starship is missing.
if command -v starship >/dev/null 2>&1; then
  _starship_init="${HOME}/.cache/starship-init.zsh"
  _starship_toml="${STARSHIP_CONFIG:-${HOME}/.config/starship.toml}"
  if [[ ! -s "$_starship_init" ]] || [[ -f "$_starship_toml" && "$_starship_toml" -nt "$_starship_init" ]]; then
    starship init zsh --print-full-init > "$_starship_init"
  fi
  source "$_starship_init"
  unset _starship_init _starship_toml
fi

# ---- fzf (fuzzy finder): Ctrl-R history, Ctrl-T files, Alt-C cd --------------
# Complements zsh-autosuggestions (inline ghosting) with an INTERACTIVE fuzzy
# picker — different job, not a replacement. Quietly skips when fzf is absent.
# Modern fzf (>=0.48) prints its own zsh integration via `fzf --zsh`; older
# distro builds ship key-bindings/completion files under a share dir instead.
# Guarded with `command -v` so a missing fzf never changes zshrc's exit status.
if command -v fzf >/dev/null 2>&1; then
  if fzf --zsh >/dev/null 2>&1; then
    source <(fzf --zsh)
  else
    for _fzf_dir in \
        "${HOMEBREW_PREFIX:-/opt/homebrew}/opt/fzf/shell" \
        /usr/share/fzf /usr/share/fzf/shell /usr/share/doc/fzf/examples; do
      [[ -r "$_fzf_dir/key-bindings.zsh" ]] && source "$_fzf_dir/key-bindings.zsh"
      [[ -r "$_fzf_dir/completion.zsh"   ]] && source "$_fzf_dir/completion.zsh"
    done
    unset _fzf_dir
  fi
  # fzf's `--zsh` integration ends by binding Tab to `fzf-completion`, stealing
  # it. Keep fzf's Ctrl-R / Ctrl-T / Alt-C widgets, but reclaim Tab for fzf-tab
  # so the structured fuzzy completion menu owns Tab. Guard on the widget
  # existing so a machine with fzf but without fzf-tab keeps its native
  # menu-select binding from the completion block above.
  if whence -w fzf-tab-complete >/dev/null 2>&1; then
    bindkey '^I' fzf-tab-complete
  fi
fi

# ---- lsd directory listings --------------------------------------------------
# lsd is installed by setup where the OS package manager carries it. Keep the
# aliases guarded so a partially provisioned shell still starts cleanly.
if command -v lsd >/dev/null 2>&1; then
  alias ls='lsd'
  alias l='lsd -l'
  alias la='lsd -a'
  alias lla='lsd -la'
  alias lt='lsd --tree'
fi

# Intentionally NOT rebinding Esc — it shadows the entire Meta prefix and
# breaks every Alt-X keybinding (including Alt-h/j/k/l set in nvim's
# vim-options.lua). If you want a single keystroke to clear the line, ^U
# (kill-whole-line) is already the readline default.

# ---- Machine-local overrides (NOT tracked) -----------------------------------
# Put anything user/machine/employer-specific here so it never lands in this
# public repo: secrets, work paths, NOTES_VAULT, $PATH tweaks, etc.
# Example: export NOTES_VAULT="$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/my-vault"
# NOTE: use an `if` block, not `[[ -f ]] && source` — the && one-liner returns
# exit 1 when the file is absent, which would become zshrc's exit status and
# break callers that check it (e.g. the zsh-startup smoke test).
if [[ -f "$HOME/.zshrc.local" ]]; then
  source "$HOME/.zshrc.local"
fi
