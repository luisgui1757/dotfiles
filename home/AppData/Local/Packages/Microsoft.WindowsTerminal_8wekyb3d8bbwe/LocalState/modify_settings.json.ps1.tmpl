{{- if ne .targetOS "windows" -}}
{{- /* off-Windows: emit nothing */ -}}
{{- else -}}
$ErrorActionPreference = 'Stop'
$currentJson = [Console]::In.ReadToEnd()
$fragmentJson = @'
{{ template "windows-terminal/settings.fragment.jsonc" . }}
'@
{{ template "windows-terminal/merge-settings.ps1" . }}

if ([string]::IsNullOrWhiteSpace($currentJson)) {
    # When Windows Terminal has never launched, settings.json does not exist and
    # chezmoi passes empty stdin. Emit NOTHING so chezmoi leaves the target
    # absent -- do NOT fabricate a settings.json; WT would overwrite a hand-made
    # file on first launch anyway.
    return
}
$current = ConvertFrom-WindowsTerminalJsonc -Jsonc $currentJson
$fragment = ConvertFrom-WindowsTerminalJsonc -Jsonc $fragmentJson
Merge-WindowsTerminalSettingsObject -Current $current -Fragment $fragment | ConvertTo-Json -Depth 100
{{- end -}}
