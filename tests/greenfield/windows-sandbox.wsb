<Configuration>
  <VGpu>Enable</VGpu>
  <Networking>Enable</Networking>
  <!-- Speed: on a high-RAM host, uncomment and bump this so the sandbox can
       cache the install I/O (e.g. 16384 = 16 GB, 32768 = 32 GB). Leave it
       commented on a low-RAM host, because requesting more RAM than the host has
       makes the sandbox fail to start.
  <MemoryInMB>16384</MemoryInMB>
  -->
  <!-- Pinned/local execution: map the repo checkout you intentionally want to
       test, then run the checked-out local sandbox-run.ps1. The relative
       HostFolder maps the repo root when this file is launched from its tracked
       location on a Windows build that supports relative .wsb mappings. If your
       host does not support that, replace HostFolder with the absolute path to
       a checkout already at the commit/ref you intend to test. -->
  <MappedFolders>
    <MappedFolder>
      <HostFolder>..\..</HostFolder>
      <SandboxFolder>C:\Users\WDAGUtilityAccount\Desktop\dotfiles-repo</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
  </MappedFolders>
  <LogonCommand>
    <Command>powershell.exe -NoExit -NoProfile -ExecutionPolicy Bypass -File "C:\Users\WDAGUtilityAccount\Desktop\dotfiles-repo\tests\greenfield\sandbox-run.ps1" -MappedRepo "C:\Users\WDAGUtilityAccount\Desktop\dotfiles-repo"</Command>
  </LogonCommand>
</Configuration>
