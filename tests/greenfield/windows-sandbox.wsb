<Configuration>
  <VGpu>Enable</VGpu>
  <Networking>Enable</Networking>
  <!-- Speed: on a high-RAM host, uncomment and bump this so the sandbox can
       cache the install I/O (e.g. 16384 = 16 GB, 32768 = 32 GB). Leave it
       commented on a low-RAM host, because requesting more RAM than the host has
       makes the sandbox fail to start.
  <MemoryInMB>16384</MemoryInMB>
  -->
  <!-- Self-contained: no mapped folder. The logon command downloads the repo and
       runs the greenfield flow, so double-clicking this .wsb works from anywhere
       (a mapped HostFolder needed Win11 22H2+ AND the repo cloned at the right
       spot). To test a different branch, change the ref in the URL below. -->
  <LogonCommand>
    <Command>powershell.exe -NoExit -NoProfile -ExecutionPolicy Bypass -Command "[Net.ServicePointManager]::SecurityProtocol=[Net.SecurityProtocolType]::Tls12; iex (irm 'https://raw.githubusercontent.com/luisgui1757/dotfiles/chezmoi-pilot/tests/greenfield/sandbox-bootstrap.ps1')"</Command>
  </LogonCommand>
</Configuration>
